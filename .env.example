# Sao chép file này thành `.env` rồi điền giá trị thật (file .env KHÔNG commit).
# Local (Docker Postgres):
DATABASE_URL=postgresql+psycopg2://anime:anime@localhost:5432/animedb
# Trên Render: dùng Internal Database URL mà Render cấp (postgres://... cũng được, app tự chuẩn hoá).

# Khoá bí mật cho session đăng nhập — đặt chuỗi ngẫu nhiên dài khi deploy.
SECRET_KEY=change-me-to-a-long-random-string
